# Copy to `.env` and fill in your local Postgres password.
# .env is gitignored — never gets committed.

# Connection to your local Postgres (the `caspase` role we created).
CASPASE_DB_URL=postgresql+asyncpg://caspase:YOUR_PASSWORD_HERE@localhost:5432/caspase

# API key used by the SDK / CLI / tests when calling the control plane.
# The matching key_hash is seeded in migration 0001 — DO NOT change without
# updating the migration too. These keys are LOCAL ONLY.
CASPASE_API_KEY=sk_dev_developer_local_only_do_not_ship

# Operator key — needed for kill operations (M4). Keep around for later.
CASPASE_OPERATOR_KEY=sk_dev_operator_local_only_do_not_ship
